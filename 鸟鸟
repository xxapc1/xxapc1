<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>鸟鸟家庭点餐</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Arial Rounded MT Bold', 'Arial', sans-serif;
        }

        body {
            background-color: #fff9e6;
            color: #333;
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        header {
            text-align: center;
            margin-bottom: 30px;
            padding: 20px;
            background-color: #ffcc80;
            border-radius: 20px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            position: relative;
        }

        h1 {
            color: #ff5722;
            font-size: 2.5rem;
            margin-bottom: 10px;
            text-shadow: 2px 2px 0 #ffcc80;
        }

        .subtitle {
            color: #795548;
            font-size: 1.2rem;
        }

        .cartoon-chef {
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 3rem;
        }

        .categories {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 30px;
        }

        .category-btn {
            padding: 10px 20px;
            background-color: #4caf50;
            color: white;
            border: none;
            border-radius: 30px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 1rem;
        }

        .category-btn:hover {
            background-color: #388e3c;
            transform: scale(1.05);
        }

        .category-btn.active {
            background-color: #ff5722;
        }

        .menu {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .dish-card {
            background-color: white;
            border-radius: 20px;
            padding: 15px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            transition: transform 0.3s;
            position: relative;
            overflow: hidden;
        }

        .dish-card:hover {
            transform: translateY(-5px);
        }

        .dish-image {
            height: 180px;
            background-color: #ffecb3;
            border-radius: 15px;
            margin-bottom: 15px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 4rem;
        }

        .dish-name {
            font-size: 1.3rem;
            color: #ff5722;
            margin-bottom: 10px;
        }

        .dish-desc {
            color: #795548;
            margin-bottom: 15px;
            font-size: 0.9rem;
        }

        .dish-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .dish-price {
            font-weight: bold;
            color: #4caf50;
            font-size: 1.2rem;
        }

        .add-btn {
            background-color: #ff9800;
            color: white;
            border: none;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            cursor: pointer;
            font-size: 1.2rem;
            transition: all 0.3s;
        }

        .add-btn:hover {
            background-color: #f57c00;
            transform: rotate(15deg);
        }

        .cart-section {
            background-color: white;
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            margin-top: 30px;
        }

        .cart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .cart-title {
            color: #ff5722;
            font-size: 1.5rem;
        }

        .cart-items {
            min-height: 100px;
            margin-bottom: 20px;
        }

        .cart-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px dashed #ffcc80;
        }

        .cart-total {
            text-align: right;
            font-size: 1.2rem;
            font-weight: bold;
            color: #ff5722;
            margin-bottom: 20px;
        }

        .checkout-btn {
            display: block;
            width: 100%;
            padding: 15px;
            background-color: #ff5722;
            color: white;
            border: none;
            border-radius: 30px;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.3s;
        }

        .checkout-btn:hover {
            background-color: #e64a19;
            transform: scale(1.02);
        }

        .empty-cart {
            text-align: center;
            color: #9e9e9e;
            padding: 20px;
        }

        @media (max-width: 768px) {
            .menu {
                grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            }
            
            .cartoon-chef {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>🍽️ 美味家庭点餐</h1>
            <p class="subtitle">选择你喜欢的菜肴，享受家庭美食时光！</p>
            <div class="cartoon-chef">👨‍🍳</div>
        </header>

        <div class="categories">
            <button class="category-btn active">全部菜品</button>
            <button class="category-btn">热销推荐</button>
            <button class="category-btn">家常菜</button>
            <button class="category-btn">汤羹类</button>
            <button class="category-btn">主食</button>
            <button class="category-btn">甜点</button>
        </div>

        <div class="menu">
            <!-- 菜品1 -->
            <div class="dish-card">
                <div class="dish-image">🍖</div>
                <h3 class="dish-name">红烧排骨</h3>
                <p class="dish-desc">精选猪小排，慢火炖煮，酱香浓郁，肉质鲜嫩</p>
                <div class="dish-footer">
                    <span class="dish-price">¥38</span>
                    <button class="add-btn">+</button>
                </div>
            </div>

            <!-- 菜品2 -->
            <div class="dish-card">
                <div class="dish-image">🐟</div>
                <h3 class="dish-name">清蒸鲈鱼</h3>
                <p class="dish-desc">新鲜鲈鱼，清蒸保留原汁原味，鲜嫩爽滑</p>
                <div class="dish-footer">
                    <span class="dish-price">¥45</span>
                    <button class="add-btn">+</button>
                </div>
            </div>

            <!-- 菜品3 -->
            <div class="dish-card">
                <div class="dish-image">🍅</div>
                <h3 class="dish-name">番茄炒蛋</h3>
                <p class="dish-desc">经典家常菜，酸甜可口，营养丰富</p>
                <div class="dish-footer">
                    <span class="dish-price">¥22</span>
                    <button class="add-btn">+</button>
                </div>
            </div>

            <!-- 菜品4 -->
            <div class="dish-card">
                <div class="dish-image">🥬</div>
                <h3 class="dish-name">蒜蓉西兰花</h3>
                <p class="dish-desc">清脆西兰花，蒜香浓郁，健康美味</p>
                <div class="dish-footer">
                    <span class="dish-price">¥18</span>
                    <button class="add-btn">+</button>
                </div>
            </div>

            <!-- 菜品5 -->
            <div class="dish-card">
                <div class="dish-image">🍲</div>
                <h3 class="dish-name">玉米排骨汤</h3>
                <p class="dish-desc">鲜甜玉米与排骨慢炖，汤鲜味美</p>
                <div class="dish-footer">
                    <span class="dish-price">¥28</span>
                    <button class="add-btn">+</button>
                </div>
            </div>

            <!-- 菜品6 -->
            <div class="dish-card">
                <div class="dish-image">🍚</div>
                <h3 class="dish-name">扬州炒饭</h3>
                <p class="dish-desc">米饭粒粒分明，配料丰富，色香味俱全</p>
                <div class="dish-footer">
                    <span class="dish-price">¥20</span>
                    <button class="add-btn">+</button>
                </div>
            </div>
        </div>

        <div class="cart-section">
            <div class="cart-header">
                <h2 class="cart-title">🛒 我的点菜单</h2>
                <span class="cart-count">已选 0 道菜</span>
            </div>
            <div class="cart-items">
                <div class="empty-cart">购物车是空的，快去添加喜欢的菜品吧！</div>
            </div>
            <div class="cart-total">总计: ¥0</div>
            <button class="checkout-btn">确认点餐</button>
        </div>
    </div>

    <script>
        // 简单的购物车功能
        document.addEventListener('DOMContentLoaded', function() {
            const addButtons = document.querySelectorAll('.add-btn');
            const cartItems = document.querySelector('.cart-items');
            const cartCount = document.querySelector('.cart-count');
            const cartTotal = document.querySelector('.cart-total');
            const emptyCart = document.querySelector('.empty-cart');
            
            let cart = [];
            let total = 0;
            
            addButtons.forEach(button => {
                button.addEventListener('click', function() {
                    const dishCard = this.closest('.dish-card');
                    const dishName = dishCard.querySelector('.dish-name').textContent;
                    const dishPrice = parseFloat(dishCard.querySelector('.dish-price').textContent.replace('¥', ''));
                    
                    // 添加到购物车
                    cart.push({ name: dishName, price: dishPrice });
                    
                    // 更新UI
                    updateCart();
                    
                    // 添加动画效果
                    this.textContent = '✓';
                    this.style.backgroundColor = '#4caf50';
                    setTimeout(() => {
                        this.textContent = '+';
                        this.style.backgroundColor = '#ff9800';
                    }, 500);
                });
            });
            
            function updateCart() {
                // 清空购物车显示
                cartItems.innerHTML = '';
                total = 0;
                
                if (cart.length === 0) {
                    cartItems.appendChild(emptyCart);
                } else {
                    emptyCart.style.display = 'none';
                    
                    // 添加购物车项目
                    cart.forEach((item, index) => {
                        const cartItem = document.createElement('div');
                        cartItem.className = 'cart-item';
                        cartItem.innerHTML = `
                            <span>${item.name}</span>
                            <span>¥${item.price}</span>
                        `;
                        cartItems.appendChild(cartItem);
                        total += item.price;
                    });
                }
                
                // 更新计数和总价
                cartCount.textContent = `已选 ${cart.length} 道菜`;
                cartTotal.textContent = `总计: ¥${total}`;
            }
            
            // 分类按钮点击效果
            const categoryButtons = document.querySelectorAll('.category-btn');
            categoryButtons.forEach(button => {
                button.addEventListener('click', function() {
                    categoryButtons.forEach(btn => btn.classList.remove('active'));
                    this.classList.add('active');
                });
            });
            
            // 结算按钮点击效果
            const checkoutBtn = document.querySelector('.checkout-btn');
            checkoutBtn.addEventListener('click', function() {
                if (cart.length === 0) {
                    alert('请先添加菜品到购物车！');
                    return;
                }
                
                alert(`点餐成功！总计：¥${total}\n感谢您的订购，美食马上就来！`);
                cart = [];
                updateCart();
            });
        });
    </script>
</body>
</html>
